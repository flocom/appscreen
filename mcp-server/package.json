{
  "name": "appscreen-mcp",
  "version": "1.0.0",
  "description": "MCP server that generates App Store screenshots (server-side port of yuzu.shot / appscreen)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "appscreen-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
